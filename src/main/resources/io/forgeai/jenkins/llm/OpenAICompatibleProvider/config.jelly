<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:c="/lib/credentials">

  <f:entry title="Endpoint" field="endpoint"
           description="Base URL for the OpenAI-compatible API. E.g. https://api.openai.com/, http://localhost:1234/ (LM Studio)">
    <f:textbox default="https://api.openai.com/"/>
  </f:entry>

  <f:entry title="Model ID" field="modelId"
           description="E.g. gpt-4o, gpt-4-turbo, deepseek-coder, mistral-7b-instruct">
    <f:textbox default="gpt-4o"/>
  </f:entry>

  <f:entry title="API Key" field="apiKeyCredentialId"
           description="Select a Secret Text credential. Leave empty for local deployments (LM Studio, vLLM) that don't require auth.">
    <c:select/>
  </f:entry>

  <f:validateButton title="Test Connection" progress="Testing..."
                    method="testConnection"
                    with="endpoint,modelId,apiKeyCredentialId"/>

</j:jelly>
